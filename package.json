{
  "name": "ts-project",
  "version": "1.0.0",
  "description": "TypeScript project template with ESLint, Prettier, Vitest and Husky",
  "type": "module",
  "imports": {
    "#src/*": {
      "development": "./src/*.ts",
      "default": "./build/*.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --conditions=development ./src/main.ts",
    "start": "node ./build/main.js",
    "init:db": "corepack pnpm prisma:generate && prisma db push && prisma db seed",
    "prisma:generate": "prisma generate",
    "clean": "rimraf ./build ./.cache",
    "build": "corepack pnpm prisma:generate && corepack pnpm clean && tsc -p ./tsconfig.build.json",
    "type:check": "tsc --noEmit --project ./tsconfig.test.json",
    "type:check:ts7": "tsc --noEmit --project ./tsconfig.test.json --stableTypeOrdering",
    "lint": "eslint . --cache",
    "lint:ci": "eslint . --cache --max-warnings=0",
    "lint-staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "check": "corepack pnpm format:check && corepack pnpm prisma:generate && corepack pnpm lint && corepack pnpm type:check && corepack pnpm test",
    "check:ci": "corepack pnpm format:check && corepack pnpm prisma:generate && corepack pnpm lint:ci && corepack pnpm type:check && corepack pnpm test:ci",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.0",
  "keywords": [],
  "engines": {
    "node": ">=22.16 <25"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-import-resolver-typescript": "^3",
    "eslint-plugin-import": "^2",
    "eslint-plugin-n": "^17",
    "eslint-plugin-promise": "^7",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15",
    "prettier": "^3",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^4.0.0"
  }
}
