generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TripRequestStatus {
  pending
  canceled
}

model TripRequest {
  id             String            @id
  requesterName  String
  origin         String
  destination    String
  departureAt    DateTime
  returnAt       DateTime
  purpose        String
  passengerCount Int
  status         TripRequestStatus @default(pending)
  createdAt      DateTime          @default(now())

  @@map("trip_requests")
}

model Holiday {
  date String @id
  name String
  type String
  year Int

  @@index([year])
  @@map("holidays")
}
